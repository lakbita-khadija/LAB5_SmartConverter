<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:paddingTop="48dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kilomètres / Miles"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <RadioGroup
        android:id="@+id/rgDistChoice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbDistOption1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Km → Miles"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbDistOption2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miles → Km"
            android:layout_marginStart="16dp"/>

    </RadioGroup>

    <EditText
        android:id="@+id/etDistInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:hint="Valeur à convertir"
        android:inputType="numberDecimal"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnDistCalc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculer"
        android:backgroundTint="#FF6F00"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvDistOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Résultat : -"
        android:textSize="16sp"
        android:layout_marginTop="12dp"/>

</LinearLayout>